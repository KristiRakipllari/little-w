# ─── Database ───────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=calm_stories
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5433/calm_stories

# ─── JWT Auth ───────────────────────────────
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=7d

# ─── Supabase Storage ──────────────────────
SUPABASE_URL=https://your-project.supabase.co/storage/v1/s3
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_BUCKET=story-assets

# ─── RevenueCat ─────────────────────────────
# Same value must be set as the Authorization header in the RevenueCat
# dashboard webhook settings (Integrations → Webhooks).
REVENUECAT_WEBHOOK_SECRET=change-this-to-a-long-random-string

# ─── API ────────────────────────────────────
API_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
