{
  "expo": {
    "name": "Calm Stories",
    "slug": "calm-stories",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F7F5EF",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.littleworld.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F5EF"
      },
      "package": "com.littleworld.app"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Little World uses your photo library so admins can attach story images."
        }
      ],
      "expo-localization"
    ]
  }
}
